<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom right shadow -->
    <item
        android:bottom="0dp"
        android:left="2dp"
        android:right="0dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="?attr/customShadowDark" />
        </shape>
    </item>

    <!-- Top left shadow (highlight) -->
    <item
        android:bottom="2dp"
        android:left="0dp"
        android:right="2dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="?attr/customShadowLight" />
        </shape>
    </item>

    <!-- Main surface -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="?attr/customSurfaceColor" />
        </shape>
    </item>
</layer-list>