<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SoundVault" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">?attr/customPrimaryColor</item>
        <item name="colorPrimaryVariant">?attr/customPrimaryColor</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">?attr/customSecondaryColor</item>
        <item name="colorSecondaryVariant">?attr/customSecondaryColor</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background and Window Colors -->
        <item name="android:windowBackground">?attr/customBackgroundColor</item>
        <item name="android:statusBarColor">?attr/customBackgroundColor</item>
        <item name="android:navigationBarColor">?attr/customBackgroundColor</item>

        <!-- Toolbar and Icon Tints -->
        <item name="colorControlNormal">?attr/customTextColor</item>
        <item name="android:textColorPrimary">?attr/customTextColor</item>
        <item name="android:textColorSecondary">?attr/customSecondaryColor</item>
        <item name="actionMenuTextColor">?attr/customTextColor</item>

        <!-- AlertDialog Style -->
        <item name="alertDialogTheme">@style/Theme.SoundVault.Dialog</item>

        <!-- Default Theme Values (Light Blue & White) -->
        <item name="customBackgroundColor">@color/blue_bg</item>
        <item name="customSurfaceColor">@color/white</item>
        <item name="customPrimaryColor">@color/blue_primary</item>
        <item name="customSecondaryColor">@color/blue_accent</item>
        <item name="customShadowDark">#D1D9E6</item>
        <item name="customShadowLight">#FFFFFF</item>
        <item name="customTextColor">#444444</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.SoundVault.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:background">?attr/customSurfaceColor</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="colorAccent">?attr/customPrimaryColor</item>
        <item name="android:textColor">?attr/customTextColor</item>
        <item name="android:textColorPrimary">?attr/customTextColor</item>
    </style>

    <!-- Light Blue & White Theme -->
    <style name="Theme.SoundVault.Blue" parent="Theme.SoundVault">
        <item name="customBackgroundColor">@color/blue_bg</item>
        <item name="customSurfaceColor">@color/white</item>
        <item name="customPrimaryColor">@color/blue_primary</item>
        <item name="customSecondaryColor">@color/blue_accent</item>
        <item name="customShadowDark">#D1D9E6</item>
        <item name="customShadowLight">#FFFFFF</item>
        <item name="customTextColor">#444444</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Red & Black Theme -->
    <style name="Theme.SoundVault.Red" parent="Theme.SoundVault">
        <item name="customBackgroundColor">@color/red_bg</item>
        <item name="customSurfaceColor">#1E1E1E</item>
        <item name="customPrimaryColor">@color/red_primary</item>
        <item name="customSecondaryColor">@color/red_accent</item>
        <item name="customShadowDark">#000000</item>
        <item name="customShadowLight">#2C2C2C</item>
        <item name="customTextColor">#EEEEEE</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Midnight Gold Theme -->
    <style name="Theme.SoundVault.Midnight" parent="Theme.SoundVault">
        <item name="customBackgroundColor">@color/midnight_bg</item>
        <item name="customSurfaceColor">#12162D</item>
        <item name="customPrimaryColor">@color/midnight_primary</item>
        <item name="customSecondaryColor">@color/midnight_accent</item>
        <item name="customShadowDark">#050714</item>
        <item name="customShadowLight">#1F2850</item>
        <item name="customTextColor">#E0E0E0</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.SoundVault.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.SoundVault.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.ActionBar">
        <item name="colorControlNormal">?attr/customTextColor</item>
    </style>

    <style name="Theme.SoundVault.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light">
        <item name="android:textColor">#444444</item>
    </style>
</resources>