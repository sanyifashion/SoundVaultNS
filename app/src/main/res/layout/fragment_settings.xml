<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/customBackgroundColor"
    tools:context=".ui.settings.SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/app_theme_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_app_theme"
            android:textColor="?attr/customTextColor"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="?attr/customSurfaceColor"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <Spinner
                android:id="@+id/appThemeSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:padding="4dp"
                android:popupBackground="?attr/customSurfaceColor" />
        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="?attr/customShadowDark" />

        <TextView
            android:id="@+id/theme_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_visualizer_style"
            android:textColor="?attr/customTextColor"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="?attr/customSurfaceColor"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <Spinner
                android:id="@+id/themeSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:padding="4dp"
                android:popupBackground="?attr/customSurfaceColor" />
        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/tapToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_allow_tap"
            android:textColor="?attr/customTextColor"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="?attr/customShadowDark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Equalizer"
            android:textColor="?attr/customTextColor"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/eq_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/eq_hint_start_playing"
            android:textColor="?attr/customSecondaryColor"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/eq_controls_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bass"
                android:textColor="?attr/customTextColor" />

            <SeekBar
                android:id="@+id/bassSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="3000"
                android:progress="1500" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Mid"
                android:textColor="?attr/customTextColor" />

            <SeekBar
                android:id="@+id/midSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="3000"
                android:progress="1500" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Treble"
                android:textColor="?attr/customTextColor" />

            <SeekBar
                android:id="@+id/trebleSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="3000"
                android:progress="1500" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="?attr/customSurfaceColor"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <Spinner
                    android:id="@+id/presetSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:padding="4dp"
                    android:popupBackground="?attr/customSurfaceColor" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/savePresetBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Save Preset"
                    app:backgroundTint="?attr/customPrimaryColor" />

                <ImageButton
                    android:id="@+id/deletePresetBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_delete"
                    android:contentDescription="Delete Preset"
                    app:tint="?attr/customPrimaryColor"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/text_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textAlignment="center"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>